# Copy to `.env` and fill in. `.env` is gitignored.

# Full connection string for the web service (docker-compose). Host must be the
# postgres service name. Password must match the postgres service password.
DB_CONNECTION_STRING=Host=postgres;Database=movies;Username=movies_rw;Password=replace-with-a-strong-password

# Seq UI login: user `admin`, this password. Min 8 chars.
SEQ_ADMIN_PASSWORD=replace-with-a-strong-password
# Hash of SEQ_ADMIN_PASSWORD, consumed by compose (SEQ_FIRSTRUN_ADMINPASSWORDHASH).
# A plaintext first-run password forces an interactive change and blocks automation,
# so we seed a permanent hash instead. Generate with:
#   echo "<password>" | docker run --rm -i datalust/seq config hash
SEQ_ADMIN_PASSWORD_HASH=replace-with-the-hash-of-SEQ_ADMIN_PASSWORD

# Seq ingestion API key token. Sent by the app as the X-Seq-ApiKey OTLP header and
# registered in Seq as an API key with the same token (seqcli apikey create --token ...).
SEQ_API_KEY=replace-with-your-seq-api-key
