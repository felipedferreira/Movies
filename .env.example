# Copy to `.env` and fill in. `.env` is gitignored.

# Full connection string for the web service (docker-compose). Host must be the
# postgres service name. Password must match the postgres service password.
DB_CONNECTION_STRING=Host=postgres;Database=cinedex;Username=cinedex_rw;Password=replace-with-a-strong-password

# Seq first-login password for user `admin`. Seq requires this on an empty
# seq_data volume, then prompts you to choose the permanent UI password.
SEQ_ADMIN_PASSWORD=replace-with-a-strong-password

# Seq ingestion API key token. Sent by the app as the X-Seq-ApiKey OTLP header and
# registered in Seq as an API key with the same token (seqcli apikey create --token ...).
SEQ_API_KEY=replace-with-your-seq-api-key
