<Project>
  <!-- Common properties for all projects in the solution -->

  <PropertyGroup>
    <!-- Versioning -->
    <Version>0.1.0</Version>
    <AssemblyVersion>0.1.0</AssemblyVersion>
    <FileVersion>0.1.0</FileVersion>
    <InformationalVersion>0.1.0</InformationalVersion>

    <!-- Target framework -->
    <TargetFramework>net10.0</TargetFramework>

    <!-- Language features -->
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <!-- Code analysis -->
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
    <EnableNETAnalyzers>true</EnableNETAnalyzers>
    <AnalysisLevel>latest</AnalysisLevel>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
  </PropertyGroup>

  <!-- NuGet package versions (centralized) -->
  <ItemGroup>
    <!-- Add shared package versions here that multiple projects use -->
    <!-- Example:
    <PackageReference Update="SomePackage" Version="1.0.0" />
    -->
  </ItemGroup>

  <!-- Code analysis packages -->
  <ItemGroup>
    <PackageReference Include="StyleCop.Analyzers" />
  </ItemGroup>

</Project>
